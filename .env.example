# Copy to .env and fill in values before first run

# Poll interval — also editable from the dashboard
POLL_INTERVAL_MINUTES=15

# Google Drive path to your Obsidian vault (rclone remote name: gdrive)
GDRIVE_VAULT_PATH=/Notes/Personal/reMarkable

# OCR — set to false to skip Surya and only produce SVGs
OCR_ENABLED=true

# Web dashboard port (LAN access: http://vm-ip:PORT)
WEB_PORT=8080
